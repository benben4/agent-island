{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Island",
  "version": "0.1.0",
  "identifier": "com.pixelagents.agentisland",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Agent Island",
        "width": 1180,
        "height": 780,
        "minWidth": 420,
        "minHeight": 120,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "shadow": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
